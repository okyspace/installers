# =============================================================================
#  _minikube/config.env  —  Edit this file to customise your local cluster.
#  install.sh sources this automatically; no need to pass env vars manually.
# =============================================================================

# ── Cluster identity ──────────────────────────────────────────────────────────
CLUSTER_NAME=general
DRIVER=docker                   # docker | kvm2 | virtualbox | none
CNI=none                        # none = Calico is installed explicitly by install_calico (recommended)
SUBNET=192.168.100.0/24
K8S_VERSION=v1.35.0             # pin a version or set 'latest' for newest minikube supports

# ── Node resources (applied to every node — minikube uses a flat resource model) ──
CPUS=16
MEMORY=12288                    # MiB (12 GB)
ENABLE_GPU=true                 # true requires nvidia-container-toolkit on host

# ── Host → VM disk mount ──────────────────────────────────────────────────────
# MOUNT_HOST is bind-mounted into every VM node at MOUNT_VM.
# data/pv/ is exposed as a Kubernetes PersistentVolume.
MOUNT_HOST=${SCRIPT_DIR}/data   # _minikube/data — change to an absolute path to use a different disk
MOUNT_VM=/mnt/data
PV_CAPACITY=60Gi               # size of the Kubernetes PersistentVolume

# ── INFRA: Calico CNI ────────────────────────────────────────────────────────
CALICO_VERSION=v3.29.3
POD_CIDR=10.244.0.0/16

# ── INFRA: MetalLB ────────────────────────────────────────────────────────────
METALLB_VERSION=0.14.9
METALLB_IP_RANGE=192.168.100.11-192.168.100.20

# ── PLATFORM: NGINX Ingress ───────────────────────────────────────────────────
NGINX_VERSION=4.12.1
NGINX_LB_IP=192.168.100.11     # first IP in MetalLB pool

# ── PLATFORM: cert-manager ────────────────────────────────────────────────────
CERT_MANAGER_VERSION=v1.16.3

# ── PLATFORM: KEDA ───────────────────────────────────────────────────────────
KEDA_VERSION=2.16.1

# ── PLATFORM: KGateway ───────────────────────────────────────────────────────
KGATEWAY_VERSION=2.0.3
GATEWAY_API_VERSION=v1.2.1
KGATEWAY_LB_IP=192.168.100.2

# ── PLATFORM: Monitoring (kube-prometheus-stack) ──────────────────────────────
PROMETHEUS_VERSION=68.3.3

# ── PLATFORM: Grafana (standalone) ────────────────────────────────────────────
GRAFANA_VERSION=8.5.2

# ── APPS: KAITO ───────────────────────────────────────────────────────────────
KAITO_VERSION=0.7.2
